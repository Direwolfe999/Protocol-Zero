# Protocol Zero — Streamlit Community Cloud secrets template
# Paste the entries you need into Streamlit Cloud > App settings > Secrets.

# --- Core chain config (required for full on-chain features) ---
RPC_URL = "https://sepolia.infura.io/v3/YOUR_KEY"
CHAIN_ID = "11155111"
PRIVATE_KEY = "YOUR_64_HEX_PRIVATE_KEY_NO_0x"
IDENTITY_REGISTRY_ADDRESS = "0x0000000000000000000000000000000000000000"
REPUTATION_REGISTRY_ADDRESS = "0x0000000000000000000000000000000000000000"
VALIDATION_REGISTRY_ADDRESS = "0x0000000000000000000000000000000000000000"

# --- AWS Bedrock (optional; app falls back if blocked/unavailable) ---
AWS_ACCESS_KEY_ID = "YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY = "YOUR_AWS_SECRET_ACCESS_KEY"
AWS_DEFAULT_REGION = "us-east-1"
BEDROCK_MODEL_ID = "us.amazon.nova-lite-v1:0"

# --- Runtime feature toggles (optional) ---
DEX_ENABLED = "false"
PZ_FORCE_DASHBOARD_MODE = "1"
PZ_CLOUD_SAFE_MODE = "1"
PZ_ULTRA_LITE_MODE = "1"
