# ══════════════════════════════════════════════════════════
#  Protocol Zero — Environment Configuration Template
# ══════════════════════════════════════════════════════════
#  Copy this file:  cp .env.example .env
#  Then fill in your real values.
# ══════════════════════════════════════════════════════════

# ── Blockchain (Sepolia Testnet) ────────────────
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111
PRIVATE_KEY=your_wallet_private_key_hex_no_0x_prefix

# ── ERC-8004 Contract Addresses (Sepolia) ───────
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ── AWS / Amazon Nova AI ────────────────────────
#  Required for full AI reasoning. If left as placeholders,
#  brain.py uses a rule-based technical analysis fallback.
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── Trading Parameters ─────────────────────────
MAX_TRADE_USD=500
MAX_DAILY_LOSS_USD=1000
TOTAL_CAPITAL_USD=10000
TRADING_PAIR=ETH/USDT

# ── DEX Execution (Uniswap V3 on Sepolia) ──────
DEX_ENABLED=false
UNISWAP_ROUTER_ADDRESS=0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48E
WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
DEX_MAX_SLIPPAGE_PCT=1.0
DEX_POOL_FEE=3000

# ── Nova Act (UI Automation Auditor) ────────────
NOVA_ACT_API_KEY=your_nova_act_api_key

# ── Agent Identity ──────────────────────────────
AGENT_NAME=ProtocolZero
AGENT_HANDLE=protocol-zero
AGENT_VERSION=1.0.0
