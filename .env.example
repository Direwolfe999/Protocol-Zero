# ============================================================
#  Protocol Zero — Environment Variables (.env)
# ============================================================
#  SECURITY RULES:
#    1. NEVER commit this file (it's in .gitignore).
#    2. Copy this template:  cp .env.example .env
#    3. Fill in real values ONLY in .env.
#    4. Keep private keys in a vault for production.
# ============================================================

# ── Amazon Bedrock (Nova Lite) ──────────────────────────────
# Optional: without these, the brain falls back to rule-based logic.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── EVM Blockchain ─────────────────────────────────────────
# RPC endpoint (Alchemy / Infura / local Anvil fork)
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
CHAIN_ID=11155111

# Bot wallet private key (WITHOUT the 0x prefix)
PRIVATE_KEY=your-64-char-hex-private-key

# ── ERC-8004 Contract Addresses ────────────────────────────
# Replace with your deployed registry addresses
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Optional: Additional ERC-8004 Contracts ────────────────
# VALIDATOR_ADDRESS=0x...
# RISK_ROUTER_ADDRESS=0x...
# CAPITAL_VAULT_ADDRESS=0x...

# ── Trading Parameters ─────────────────────────────────────
MAX_TRADE_USD=500
MAX_DAILY_LOSS_USD=1000
TRADING_PAIR=BTC/USDT
LOOP_INTERVAL_SECONDS=60
TOTAL_CAPITAL_USD=10000

# ── DEX Execution (Uniswap V3 on Sepolia) ──────────────────
# Set DEX_ENABLED=true to activate live swaps — off by default.
DEX_ENABLED=false
# UNISWAP_ROUTER_ADDRESS=0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48E
# WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
# USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# DEX_MAX_SLIPPAGE_PCT=1.0
# DEX_POOL_FEE=3000

# ── Agent Identity ──────────────────────────────────────────
AGENT_NAME=ProtocolZero
AGENT_HANDLE=protocol-zero
AGENT_VERSION=1.0.0

# ── Nova Sonic (Voice AI) — optional ───────────────────────
# NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0
# NOVA_SONIC_ENABLED=false

# ── Nova Act (UI Automation) — optional ────────────────────
# NOVA_ACT_ENABLED=false
# NOVA_ACT_API_KEY=your-nova-act-api-key

# ── Nova Multimodal Embeddings — optional ──────────────────
# NOVA_EMBED_MODEL_ID=amazon.nova-embed-multimodal-v1:0
# NOVA_EMBED_ENABLED=false
