# ============================================================
#  Protocol Zero — Environment Variables (.env)
# ============================================================
#  SECURITY RULES:
#    1. NEVER commit this file (it's in .gitignore).
#    2. Copy this template:  cp .env.example .env
#    3. Fill in real values ONLY in .env.
#    4. Keep private keys in a vault for production.
# ============================================================

# ── Amazon Bedrock (Nova Lite) ──────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── EVM Blockchain ─────────────────────────────────────────
# RPC endpoint (Alchemy / Infura / local Anvil fork)
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
CHAIN_ID=11155111

# Bot wallet private key (WITHOUT the 0x prefix)
PRIVATE_KEY=your-64-char-hex-private-key

# ── ERC-8004 Contract Addresses ────────────────────────────
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Trading Parameters ─────────────────────────────────────
MAX_TRADE_USD=500
MAX_DAILY_LOSS_USD=1000
TRADING_PAIR=BTC/USDT
LOOP_INTERVAL_SECONDS=60
